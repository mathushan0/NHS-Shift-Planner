# NHS Shift Planner — Fastlane Configuration
# Handles iOS builds and TestFlight uploads.
# Primary CI/CD path uses EAS Build; Fastlane is the fallback / local build path.
#
# Setup:
#   gem install bundler
#   bundle install
#   bundle exec fastlane <lane>
#
# Required environment variables (see .env.example):
#   APPLE_ID, ASC_APP_ID, APPLE_TEAM_ID
#   FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD or ASC_API_KEY_ID + ASC_API_ISSUER_ID + ASC_API_KEY_CONTENT_BASE64

default_platform(:ios)

# ─────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────

def load_asc_api_key
  # Prefer App Store Connect API key over app-specific password
  if ENV["ASC_API_KEY_ID"] && ENV["ASC_API_ISSUER_ID"] && ENV["ASC_API_KEY_CONTENT_BASE64"]
    # Write the base64-decoded key to a temp file
    key_path = "/tmp/asc_api_key.p8"
    File.write(key_path, Base64.decode64(ENV["ASC_API_KEY_CONTENT_BASE64"]))
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_API_ISSUER_ID"],
      key_filepath: key_path,
      duration: 1200,
      in_house: false
    )
  else
    UI.important("ASC API key not configured — falling back to Apple ID + app-specific password")
    nil
  end
end

# ─────────────────────────────────────────────
# iOS LANES
# ─────────────────────────────────────────────

platform :ios do

  desc "Fetch or refresh code signing certificates and profiles"
  lane :certificates do
    api_key = load_asc_api_key
    match(
      type: "appstore",
      app_identifier: ENV["IOS_BUNDLE_IDENTIFIER"] || "com.yourname.nhsshiftplanner",
      api_key: api_key,
      readonly: is_ci,
      git_url: ENV["MATCH_GIT_URL"],        # private git repo for certificates
      git_branch: "main",
      clone_branch_directly: true
    )
  end

  desc "Build the iOS app (release) without uploading"
  lane :build do
    api_key = load_asc_api_key

    # Increment build number
    increment_build_number(
      xcodeproj: "ios/NHSShiftPlanner.xcodeproj"
    )

    # Install pods
    cocoapods(
      podfile: "ios/Podfile",
      use_bundle_exec: true
    )

    # Fetch signing certificates
    certificates

    # Build
    gym(
      workspace: "ios/NHSShiftPlanner.xcworkspace",
      scheme: "NHSShiftPlanner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "NHSShiftPlanner.ipa",
      clean: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = load_asc_api_key

    build

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/NHSShiftPlanner.ipa",
      app_identifier: ENV["IOS_BUNDLE_IDENTIFIER"] || "com.yourname.nhsshiftplanner",
      skip_waiting_for_build_processing: true,
      changelog: last_git_commit[:message]
    )

    UI.success("✅ Successfully uploaded to TestFlight!")
    notification(
      title: "NHS Shift Planner",
      message: "TestFlight build uploaded successfully"
    ) unless is_ci
  end

  desc "Build and submit to App Store (manual review required)"
  lane :release do
    api_key = load_asc_api_key

    build

    upload_to_app_store(
      api_key: api_key,
      ipa: "./build/NHSShiftPlanner.ipa",
      app_identifier: ENV["IOS_BUNDLE_IDENTIFIER"] || "com.yourname.nhsshiftplanner",
      skip_metadata: false,
      skip_screenshots: true,
      submit_for_review: false,  # Manual review trigger — don't auto-submit
      force: true,
      precheck_include_in_app_purchases: false
    )

    UI.success("✅ App uploaded to App Store. Submit for review manually in App Store Connect.")
  end

  desc "Run tests"
  lane :test do
    run_tests(
      workspace: "ios/NHSShiftPlanner.xcworkspace",
      scheme: "NHSShiftPlanner",
      devices: ["iPhone 15 Pro"],
      reset_simulator: true,
      clean: true
    )
  end

  # ──────────────────────────────────────────
  # Error handling
  # ──────────────────────────────────────────

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
    if is_ci
      # Post failure info to stdout for GitHub Actions to capture
      puts "FASTLANE_FAILURE: #{lane} — #{exception.message}"
    end
  end

end
