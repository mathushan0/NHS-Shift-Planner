# NHS Shift Planner — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
#
# Prefix EXPO_PUBLIC_ = bundled into the app (safe for anon keys, URLs)
# No prefix = server-side / CI only (secrets, service role keys)

# ─────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────

# Your Supabase project URL (safe to expose — RLS protects data)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous key (safe to expose — RLS enforces access control)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key — NEVER bundle in app; CI/server use only
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase project reference (used by CLI)
SUPABASE_PROJECT_REF=your-project-ref

# ─────────────────────────────────────────────
# APP ENVIRONMENT
# ─────────────────────────────────────────────

# Environment identifier: development | preview | production
EXPO_PUBLIC_APP_ENV=development

# App variant (matches EAS build profile)
APP_VARIANT=development

# ─────────────────────────────────────────────
# EXPO / EAS
# ─────────────────────────────────────────────

# Expo account token — CI/CD use only (generate at expo.dev/accounts/<account>/settings/access-tokens)
EXPO_TOKEN=your-expo-access-token

# ─────────────────────────────────────────────
# APPLE / APP STORE (CI/CD + Fastlane)
# ─────────────────────────────────────────────

# Apple ID for App Store Connect login
APPLE_ID=your-apple-id@example.com

# App Store Connect App ID (numeric — found in App Store Connect > App > General)
ASC_APP_ID=1234567890

# Apple Developer Team ID (found at developer.apple.com/account)
APPLE_TEAM_ID=XXXXXXXXXX

# App-specific password for altool/Transporter (generate at appleid.apple.com)
# Used by Fastlane for TestFlight uploads
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# App Store Connect API Key ID (optional — preferred over app-specific password for CI)
ASC_API_KEY_ID=XXXXXXXXXX

# App Store Connect API Issuer ID
ASC_API_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App Store Connect API private key content (base64-encoded .p8 file)
ASC_API_KEY_CONTENT_BASE64=base64-encoded-private-key-content

# ─────────────────────────────────────────────
# BUNDLE IDENTIFIER
# ─────────────────────────────────────────────

# iOS bundle identifier (must match app.json and App Store Connect)
IOS_BUNDLE_IDENTIFIER=com.yourname.nhsshiftplanner

# ─────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────

# Enable cloud sync UI (set to 'true' to show sync features)
EXPO_PUBLIC_ENABLE_CLOUD_SYNC=false

# Enable debug logging in non-production builds
EXPO_PUBLIC_ENABLE_DEBUG_LOGGING=true
